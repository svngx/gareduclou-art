---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Alle Stücke laden
const spurweite = await getCollection('spurweite');
const passage = await getCollection('passage');
const ankunft = await getCollection('ankunft');
const alle = [...spurweite, ...passage, ...ankunft];

// Stück über ID finden
const { id } = Astro.params;
const stueck = alle.find(s => s.data.pfad === id);
if (!stueck) return Astro.redirect('/');

// Inhalt rendern
const { Content } = await stueck.render();

// Bezüge auflösen (bidirektional)
const bezugIds = new Set(stueck.data.bezuege);
for (const s of alle) {
  if (s.data.bezuege.includes(stueck.data.pfad)) {
    bezugIds.add(s.data.pfad);
  }
}
bezugIds.delete(stueck.data.pfad);
const bezuege = alle.filter(s => bezugIds.has(s.data.pfad));

// Register-Farbe
const col: Record<string, string> = {
  spurweite: 'var(--spurweite)',
  passage: 'var(--passage)',
  ankunft: 'var(--ankunft)',
};
const rl: Record<string, string> = {
  spurweite: 'spur||weite',
  passage: '/passage/',
  ankunft: 'an//kunft',
};

export async function getStaticPaths() {
  const spurweite = await getCollection('spurweite');
  const passage = await getCollection('passage');
  const ankunft = await getCollection('ankunft');
  return [...spurweite, ...passage, ...ankunft].map(s => ({
    params: { id: s.data.pfad },
  }));
}
---
<Base title={`${stueck.data.title.de} — Gare du Clou`}>
  <div class="stueck-page">
    <nav class="top-bar">
      <a href="/" class="back">← Rhizom</a>
      <span class="register-badge" style={`color: ${col[stueck.data.register]}`}>
        {rl[stueck.data.register]}
      </span>
    </nav>

    <article class="inhalt">
      <h1>{stueck.data.title.de}</h1>
      {stueck.data.title.en && (
        <p class="en-title">{stueck.data.title.en}</p>
      )}

      <div class="schichten-toggle">
        {stueck.data.schichten.map(s => (
          <button class="schicht-btn" data-schicht={s}>{s}</button>
        ))}
      </div>

      <div class="body-content">
        <Content />
      </div>
    </article>

    {bezuege.length > 0 && (
      <aside class="bezuege-section">
        <h3 class="bezuege-title">Bezüge</h3>
        {bezuege.map(b => (
          <a href={`/${b.data.pfad}`} class="bezug-link">
            <span class="bezug-dot" style={`background: ${col[b.data.register]}`}></span>
            <span class="bezug-name">{b.data.title.de}</span>
            <span class="bezug-reg">{rl[b.data.register]}</span>
          </a>
        ))}
      </aside>
    )}
  </div>

  <!-- Schichten-Toggle -->
  <script is:inline>
  (function() {
    var btns = document.querySelectorAll('.schicht-btn');
    var sections = document.querySelectorAll('section[data-schicht]');

    // Kern ist immer aktiv
    var active = { kern: true };

    function update() {
      btns.forEach(function(b) {
        var s = b.getAttribute('data-schicht');
        if (active[s]) b.classList.add('active');
        else b.classList.remove('active');
      });
      sections.forEach(function(sec) {
        var s = sec.getAttribute('data-schicht');
        if (active[s]) {
          sec.style.display = '';
          sec.style.opacity = '1';
        } else {
          sec.style.display = 'none';
        }
      });
    }

    btns.forEach(function(b) {
      b.addEventListener('click', function() {
        var s = b.getAttribute('data-schicht');
        if (s === 'kern') return; // Kern bleibt immer an
        active[s] = !active[s];
        update();
      });
    });

    // Initial: nur Kern sichtbar
    update();
  })();
  </script>
</Base>

<style>
  .stueck-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 60px 24px 80px 24px;
  }
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }
  .back {
    font-family: var(--font-system);
    font-size: 11px;
    color: var(--text-muted);
  }
  .back:hover { color: var(--text-secondary); }
  .register-badge {
    font-family: var(--font-system);
    font-size: 11px;
    letter-spacing: 0.05em;
  }
  h1 {
    font-family: var(--font-inhalt);
    font-size: 24px;
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: 6px;
  }
  .en-title {
    font-family: var(--font-inhalt);
    font-size: 15px;
    color: var(--text-muted);
    font-style: italic;
    margin-bottom: 24px;
  }
  .schichten-toggle {
    display: flex;
    gap: 6px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .schicht-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    padding: 3px 10px;
    border-radius: 3px;
    cursor: pointer;
    font-family: var(--font-system);
    font-size: 11px;
    text-transform: capitalize;
  }
  .schicht-btn:hover,
  .schicht-btn.active {
    border-color: #555;
    color: var(--text-primary);
    background: var(--surface);
  }
  .body-content {
    font-family: var(--font-inhalt);
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-primary);
  }
  .body-content :global(p) {
    margin-bottom: 1em;
  }
  .body-content :global(strong) {
    font-weight: 600;
    color: var(--accent);
  }
  /* Schicht-Sections */
  .body-content :global(.schicht) {
    border-left: 2px solid #444;
    padding-left: 14px;
    margin-bottom: 20px;
  }
  .body-content :global(.schicht--kern) {
    border-left-color: var(--accent);
  }
  .body-content :global(.schicht--annotation) {
    border-left-color: #8a7f65;
  }
  .body-content :global(.schicht--annotation)::before {
    content: '\00B6 Annotation';
    display: block;
    font-family: var(--font-system);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #8a7f65;
    margin-bottom: 8px;
  }
  .body-content :global(.schicht--werkstatt) {
    border-left-color: #5a6a7a;
  }
  .body-content :global(.schicht--werkstatt)::before {
    content: '\2692 Werkstatt';
    display: block;
    font-family: var(--font-system);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #5a6a7a;
    margin-bottom: 8px;
  }
  .body-content :global(.schicht--quellen) {
    border-left-color: #7a8a9a;
  }
  .body-content :global(.schicht--quellen)::before {
    content: '\203B Quellen';
    display: block;
    font-family: var(--font-system);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #7a8a9a;
    margin-bottom: 8px;
  }
  .body-content :global(.schicht--quellen p) {
    font-size: 13px;
    color: var(--text-secondary);
  }
  .bezuege-section {
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .bezuege-title {
    font-family: var(--font-system);
    font-size: 10px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
    font-weight: 400;
  }
  .bezug-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border: 1px solid var(--border);
    border-radius: 3px;
    margin-bottom: 6px;
    transition: border-color 0.15s;
  }
  .bezug-link:hover { border-color: #555; }
  .bezug-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .bezug-name {
    font-family: var(--font-inhalt);
    font-size: 13px;
    color: var(--text-secondary);
  }
  .bezug-reg {
    font-family: var(--font-system);
    font-size: 9px;
    color: var(--text-muted);
    margin-left: auto;
  }
</style>
