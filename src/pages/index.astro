---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Alle Stücke aus allen Registern laden
const spurweite = await getCollection('spurweite');
const passage = await getCollection('passage');
const ankunft = await getCollection('ankunft');
const alleStuecke = [...spurweite, ...passage, ...ankunft];

// Knoten-Daten für das Rhizom-Canvas
const knoten = alleStuecke.map(s => ({
  id: s.data.pfad,
  register: s.data.register,
  de: s.data.title.de,
  en: s.data.title.en || s.data.title.de,
  bezuege: s.data.bezuege,
  schichten: s.data.schichten,
}));

// Registerfarben und -namen
const COL: Record<string, string> = {
  spurweite: '#6b8f71', passage: '#8a7f65', ankunft: '#8f6b6b'
};
const RL: Record<string, string> = {
  spurweite: 'spur||weite', passage: '/passage/', ankunft: 'an//kunft'
};
const LM: Record<string, {de: string, en: string, icon: string}> = {
  kern: {de:'Kern', en:'Core', icon:'◉'},
  annotation: {de:'Annotation', en:'Annotation', icon:'¶'},
  werkstatt: {de:'Werkstatt', en:'Workshop', icon:'⚒'},
  quellen: {de:'Quellen', en:'Sources', icon:'※'},
};

// Bezüge bidirektional auflösen
const bezuegeMap: Record<string, string[]> = {};
for (const s of alleStuecke) {
  const pfad = s.data.pfad;
  if (!bezuegeMap[pfad]) bezuegeMap[pfad] = [...s.data.bezuege];
  for (const b of s.data.bezuege) {
    if (!bezuegeMap[b]) bezuegeMap[b] = [];
    if (!bezuegeMap[b].includes(pfad)) bezuegeMap[b].push(pfad);
  }
}

// Alle Stücke rendern
const rendered = await Promise.all(alleStuecke.map(async (s) => {
  const { Content } = await s.render();
  return { pfad: s.data.pfad, Content };
}));
const contentMap = Object.fromEntries(rendered.map(r => [r.pfad, r.Content]));

// Lookup
const stueckMap = Object.fromEntries(alleStuecke.map(s => [s.data.pfad, s]));
---
<Base title="Gare du Clou">
  <div id="header">
    <div class="logo-area">
      <span class="logo">Gare du Clou</span>
      <span class="sub">Inter-Esse</span>
    </div>
    <div class="hdr-right">
      <span class="leg"><span class="ld" style="background:#6b8f71"></span> spur||weite</span>
      <span class="leg"><span class="ld" style="background:#8a7f65"></span> /passage/</span>
      <span class="leg"><span class="ld" style="background:#8f6b6b"></span> an//kunft</span>
      <button class="btn" id="langBtn">DE → EN</button>
    </div>
  </div>

  <canvas id="c"></canvas>
  <div id="hint"></div>

  <!-- Panel mit vorgerendertem Inhalt aller Stücke -->
  <div id="panel">
    <button id="cb">×</button>
    <div id="pc">
      {alleStuecke.map(s => {
        const pfad = s.data.pfad;
        const col = COL[s.data.register];
        const rl = RL[s.data.register];
        const bez = (bezuegeMap[pfad] || []).map(b => stueckMap[b]).filter(Boolean);
        const ContentComp = contentMap[pfad];
        return (
          <div class="panel-stueck" data-panel={pfad} style="display:none">
            <div class="rb" style={`color:${col}`}>{rl}</div>
            <h2 class="panel-title">{s.data.title.de}</h2>

            <div class="lt">
              {['kern','annotation','werkstatt','quellen'].map(lid => {
                const has = s.data.schichten.includes(lid as any);
                const cls = !has && lid !== 'kern' ? 'lb off' : 'lb';
                return (
                  <button class={cls} data-layer={lid} data-for={pfad}>
                    {LM[lid].icon} {LM[lid].de}
                  </button>
                );
              })}
            </div>

            <div class="panel-body">
              <ContentComp />
            </div>

            {bez.length > 0 && (
              <div class="bz">
                <div class="bzt">Bezüge</div>
                {bez.map(b => (
                  <button class="bzb" data-goto={b.data.pfad}>
                    <span class="bd" style={`background:${COL[b.data.register]}`}></span>
                    <span>{b.data.title.de}</span>
                    <span class="br">{RL[b.data.register]}</span>
                  </button>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>

  <!-- Knoten-Daten -->
  <script define:vars={{ knoten }}>
    window.__GDC_KNOTEN__ = knoten;
  </script>

  <!-- Rhizom-Engine -->
  <script src="/rhizom.js" is:inline></script>
</Base>

<style>
  #header {
    position: fixed; top: 0; left: 0; right: 0; height: 44px; z-index: 20;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 16px; border-bottom: 1px solid #2a2a2a;
    background: rgba(10,10,10,0.95);
  }
  .logo-area { display: flex; align-items: center; }
  .logo { font-family: monospace; font-size: 13px; color: #c4b89a; }
  .sub { font-family: monospace; font-size: 10px; color: #5a5651; margin-left: 10px; }
  .hdr-right { display: flex; align-items: center; gap: 12px; }
  .leg { display: flex; align-items: center; gap: 4px; font-family: monospace; font-size: 10px; color: #5a5651; }
  .ld { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
  .btn {
    background: transparent; border: 1px solid #2a2a2a; color: #8a857e;
    padding: 2px 8px; border-radius: 3px; cursor: pointer;
    font-family: monospace; font-size: 11px;
  }
  .btn:hover { border-color: #555; color: #e8e4df; }
  canvas { display: block; position: fixed; top: 0; left: 0; }
  #hint {
    position: fixed; bottom: 24px; left: 0; right: 0; text-align: center;
    font-family: monospace; font-size: 11px; color: #5a5651;
    z-index: 5; pointer-events: none;
  }

  /* Panel — wie im Prototyp */
  #panel {
    position: fixed; right: 0; top: 0; bottom: 0; width: 400px;
    background: #111; border-left: 1px solid #2a2a2a;
    overflow-y: auto; padding: 52px 20px 20px 20px; z-index: 15; display: none;
  }
  #panel.open { display: block; }
  #cb {
    position: absolute; top: 10px; right: 10px; background: transparent;
    border: none; color: #5a5651; cursor: pointer;
    font-size: 18px; font-family: monospace; padding: 4px 8px;
  }
  #cb:hover { color: #e8e4df; }

  /* Panel-Inhalt */
  .rb { font-family: monospace; font-size: 11px; margin-bottom: 4px; letter-spacing: 0.05em; }
  :global(#panel h2) { font-family: Georgia, serif; font-size: 19px; font-weight: 400; margin: 0 0 16px 0; line-height: 1.3; }
  .lt { display: flex; gap: 5px; margin-bottom: 16px; flex-wrap: wrap; }
  .lb {
    background: transparent; border: 1px solid #2a2a2a; color: #8a857e;
    padding: 3px 8px; border-radius: 3px; cursor: pointer;
    font-family: monospace; font-size: 11px;
  }
  .lb.on { background: #1a1a1a; border-color: #555; color: #e8e4df; }
  .lb.off { opacity: 0.3; cursor: default; }

  /* Schicht-Blöcke im Panel */
  :global(.panel-body .schicht) {
    border-left: 2px solid #444;
    padding-left: 12px;
    margin-bottom: 14px;
  }
  :global(.panel-body .schicht--kern) {
    border-left-color: inherit;
  }
  :global(.panel-body .schicht--kern p) {
    font-family: Georgia, serif; font-size: 14px; line-height: 1.6; color: #e8e4df;
  }
  :global(.panel-body .schicht--annotation) { border-left-color: #8a7f65; }
  :global(.panel-body .schicht--annotation)::before {
    content: '\00B6 Annotation'; display: block;
    font-family: monospace; font-size: 10px; text-transform: uppercase;
    letter-spacing: 0.06em; color: #8a7f65; margin-bottom: 6px;
  }
  :global(.panel-body .schicht--annotation p) {
    font-family: Georgia, serif; font-size: 13px; line-height: 1.6; color: #8a857e;
  }
  :global(.panel-body .schicht--werkstatt) { border-left-color: #5a6a7a; }
  :global(.panel-body .schicht--werkstatt)::before {
    content: '\2692 Werkstatt'; display: block;
    font-family: monospace; font-size: 10px; text-transform: uppercase;
    letter-spacing: 0.06em; color: #5a6a7a; margin-bottom: 6px;
  }
  :global(.panel-body .schicht--werkstatt p) {
    font-family: Georgia, serif; font-size: 13px; line-height: 1.6; color: #8a857e;
  }
  :global(.panel-body .schicht--quellen) { border-left-color: #7a8a9a; }
  :global(.panel-body .schicht--quellen)::before {
    content: '\203B Quellen'; display: block;
    font-family: monospace; font-size: 10px; text-transform: uppercase;
    letter-spacing: 0.06em; color: #7a8a9a; margin-bottom: 6px;
  }
  :global(.panel-body .schicht--quellen p) {
    font-family: Georgia, serif; font-size: 13px; line-height: 1.6; color: #8a857e;
  }

  /* Bezüge */
  .bz { margin-top: 20px; border-top: 1px solid #2a2a2a; padding-top: 12px; }
  .bzt { font-family: monospace; font-size: 10px; color: #5a5651; margin-bottom: 8px; text-transform: uppercase; }
  .bzb {
    background: transparent; border: 1px solid #2a2a2a; border-radius: 3px;
    padding: 5px 8px; cursor: pointer; text-align: left;
    display: flex; align-items: center; gap: 6px; width: 100%;
    margin-bottom: 4px; color: #8a857e; font-family: Georgia, serif; font-size: 12px;
  }
  .bzb:hover { border-color: #666; }
  .bd { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .br { font-family: monospace; font-size: 9px; color: #5a5651; margin-left: auto; }
</style>
