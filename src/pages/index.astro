---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Alle Stücke aus allen Registern laden
const spurweite = await getCollection('spurweite');
const passage = await getCollection('passage');
const ankunft = await getCollection('ankunft');
const alleStuecke = [...spurweite, ...passage, ...ankunft];

// Knoten-Daten für das Rhizom-Canvas aufbereiten
const knoten = alleStuecke.map(s => ({
  id: s.data.id,
  register: s.data.register,
  de: s.data.title.de,
  en: s.data.title.en || s.data.title.de,
  bezuege: s.data.bezuege,
  schichten: s.data.schichten,
  slug: s.slug,
}));
---
<Base title="Gare du Clou">
  <div id="header">
    <div class="logo-area">
      <span class="logo">Gare du Clou</span>
      <span class="sub">Inter-Esse</span>
    </div>
    <div class="hdr-right">
      <span class="leg"><span class="ld" style="background:var(--spurweite)"></span> spur||weite</span>
      <span class="leg"><span class="ld" style="background:var(--passage)"></span> /passage/</span>
      <span class="leg"><span class="ld" style="background:var(--ankunft)"></span> an//kunft</span>
      <button class="btn" id="langBtn">DE → EN</button>
    </div>
  </div>

  <canvas id="c"></canvas>
  <div id="hint"></div>
  <div id="panel"><button id="cb">×</button><div id="pc"></div></div>

  <!-- Knoten-Daten aus Content Collections -->
  <script define:vars={{ knoten }}>
    window.__GDC_KNOTEN__ = knoten;
  </script>

  <!-- Rhizom-Engine -->
  <script src="/rhizom.js"></script>
</Base>

<style>
  #header {
    position: fixed; top: 0; left: 0; right: 0; height: 44px; z-index: 20;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 16px; border-bottom: 1px solid var(--border);
    background: rgba(10,10,10,0.95);
  }
  .logo-area { display: flex; align-items: center; }
  .logo { font-family: var(--font-system); font-size: 13px; color: var(--accent); }
  .sub { font-family: var(--font-system); font-size: 10px; color: var(--text-muted); margin-left: 10px; }
  .hdr-right { display: flex; align-items: center; gap: 12px; }
  .leg { display: flex; align-items: center; gap: 4px; font-family: var(--font-system); font-size: 10px; color: var(--text-muted); }
  .ld { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
  .btn {
    background: transparent; border: 1px solid var(--border); color: var(--text-secondary);
    padding: 2px 8px; border-radius: 3px; cursor: pointer;
    font-family: var(--font-system); font-size: 11px;
  }
  .btn:hover { border-color: #555; color: var(--text-primary); }
  canvas { display: block; position: fixed; top: 0; left: 0; }
  #hint {
    position: fixed; bottom: 24px; left: 0; right: 0; text-align: center;
    font-family: var(--font-system); font-size: 11px; color: var(--text-muted);
    z-index: 5; pointer-events: none;
  }
  #panel {
    position: fixed; right: 0; top: 0; bottom: 0; width: 400px;
    background: var(--surface); border-left: 1px solid var(--border);
    overflow-y: auto; padding: 52px 20px 20px 20px; z-index: 15; display: none;
  }
  #panel.open { display: block; }
  #cb {
    position: absolute; top: 10px; right: 10px; background: transparent;
    border: none; color: var(--text-muted); cursor: pointer;
    font-size: 18px; font-family: var(--font-system); padding: 4px 8px;
  }
  #cb:hover { color: var(--text-primary); }
</style>
