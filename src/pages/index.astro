---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Alle Stücke aus allen Registern laden
const spurweite = await getCollection('spurweite');
const passage = await getCollection('passage');
const ankunft = await getCollection('ankunft');
const alleStuecke = [...spurweite, ...passage, ...ankunft];

// Knoten-Daten für das Rhizom-Canvas
const knoten = alleStuecke.map(s => ({
  id: s.data.pfad,
  register: s.data.register,
  de: s.data.title.de,
  en: s.data.title.en || s.data.title.de,
  bezuege: s.data.bezuege,
  schichten: s.data.schichten,
}));

// Registerfarben und -namen (Figma-Tokens, Stand 13.04.2026)
const COL: Record<string, string> = {
  spurweite: '#ff0000', passage: '#002395', ankunft: '#ffffff'
};
// Schicht-Linienfarben (Copy_line)
const LCOL: Record<string, string> = {
  kern: '', // wird pro Register gesetzt
  annotation: '#FE6901', // Orange — Figma-Variable
  werkstatt: '#afafaf',
  quellen: '#afafaf',
};
const RL: Record<string, string> = {
  spurweite: 'spur||weite', passage: '/passage/', ankunft: 'an//kunft'
};
const LM: Record<string, {de: string, en: string}> = {
  kern: {de:'Kern', en:'Core'},
  annotation: {de:'Annotation', en:'Annotation'},
  werkstatt: {de:'Werkstatt', en:'Workshop'},
  quellen: {de:'Quellen', en:'Sources'},
};

// Bezüge bidirektional auflösen
const bezuegeMap: Record<string, string[]> = {};
for (const s of alleStuecke) {
  const pfad = s.data.pfad;
  if (!bezuegeMap[pfad]) bezuegeMap[pfad] = [...s.data.bezuege];
  for (const b of s.data.bezuege) {
    if (!bezuegeMap[b]) bezuegeMap[b] = [];
    if (!bezuegeMap[b].includes(pfad)) bezuegeMap[b].push(pfad);
  }
}

// Alle Stücke rendern
const rendered = await Promise.all(alleStuecke.map(async (s) => {
  const { Content } = await s.render();
  return { pfad: s.data.pfad, Content };
}));
const contentMap = Object.fromEntries(rendered.map(r => [r.pfad, r.Content]));

// Lookup
const stueckMap = Object.fromEntries(alleStuecke.map(s => [s.data.pfad, s]));
---
<Base title="Gare du Clou">
  <div id="header">
    <div class="logo-area">
      <img src="/GDClogo.gif" alt="Gare du Clou" class="logo-img" />
    </div>
    <div class="hdr-right">
      <span class="leg"><span class="ld" style="background:#ff0000"></span> spur||weite</span>
      <span class="leg"><span class="ld" style="background:#002395"></span> /passage/</span>
      <span class="leg"><span class="ld" style="background:#ffffff"></span> an//kunft</span>
      <span class="lang" id="langBtn">DE | EN</span>
    </div>
  </div>

  <canvas id="c"></canvas>
  <div id="hint"></div>

  <!-- Panel mit vorgerendertem Inhalt aller Stücke -->
  <div id="panel">
    <button id="cb">×</button>
    <div id="pc">
      {alleStuecke.map(s => {
        const pfad = s.data.pfad;
        const col = COL[s.data.register];
        const rl = RL[s.data.register];
        const bez = (bezuegeMap[pfad] || []).map(b => stueckMap[b]).filter(Boolean);
        const ContentComp = contentMap[pfad];
        return (
          <div class="panel-stueck" data-panel={pfad} style="display:none">
            {/* Register-Overline + Titel */}
            <div class="rb" style={`color:${col}`}>{rl}</div>
            <h2 class="panel-title">{s.data.title.de}</h2>

            {/* Separator → Selector → Separator (Figma y=69..98) */}
            <div class="sep"></div>
            <div class="lt">
              {['kern','annotation','werkstatt','quellen'].map(lid => {
                const has = s.data.schichten.includes(lid as any);
                const cls = !has && lid !== 'kern' ? 'lb off' : 'lb';
                return (
                  <button class={cls} data-layer={lid} data-for={pfad}>
                    {LM[lid].de}
                  </button>
                );
              })}
            </div>
            <div class="sep"></div>

            {/* Scrollbare Schicht-Blöcke mit Copy_line */}
            <div class="panel-body" style={`color:${col}`}>
              <ContentComp />
            </div>

            {/* Separator vor Bezüge */}
            {bez.length > 0 && <div class="sep"></div>}

            {bez.length > 0 && (
              <div class="bz">
                {bez.map(b => (
                  <button class="bzb" data-goto={b.data.pfad}>
                    <span class="bd" style={`background:${COL[b.data.register]}`}></span>
                    <span>{b.data.title.de}</span>
                    <span class="br">{RL[b.data.register]}</span>
                  </button>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>

  <!-- Knoten-Daten -->
  <script define:vars={{ knoten }}>
    window.__GDC_KNOTEN__ = knoten;
  </script>

  <!-- Rhizom-Engine -->
  <script src="/rhizom.js" is:inline></script>
</Base>

<style>
  /* ── Header — Figma: Separator bei y=49, Logo links, Legende+Lang rechts ── */
  #header {
    position: fixed; top: 0; left: 0; right: 0; height: 49px; z-index: 20;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 19px; border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,0.95);
  }
  .logo-area { display: flex; align-items: center; }
  .logo-img { height: 45px; width: 108px; object-fit: contain; }
  .hdr-right { display: flex; align-items: center; gap: 12px; }
  .leg { display: flex; align-items: center; gap: 4px; font-family: var(--font-label); font-size: 10px; color: var(--text-secondary); }
  .ld { width: 5px; height: 5px; border-radius: 50%; display: inline-block; }
  .lang {
    font-family: var(--font-titel); font-size: 11px; color: var(--text-primary);
    cursor: pointer;
  }
  canvas { display: block; position: fixed; top: 0; left: 0; }
  #hint {
    position: fixed; bottom: 24px; left: 0; right: 0; text-align: center;
    font-family: var(--font-inhalt); font-size: 11px; color: var(--text-secondary);
    z-index: 5; pointer-events: none;
  }

  /* ── Panel — Figma state:klick: Text-Frame 363×782, CLIPS ── */
  #panel {
    position: fixed; right: 0; top: 49px; bottom: 0; width: 363px;
    background: var(--bg); border-left: 1px solid var(--border);
    overflow: hidden; z-index: 15; display: none;
    /* Panel selbst clippt — innere Bereiche scrollen */
  }
  #panel.open { display: flex; flex-direction: column; }
  #cb {
    position: absolute; top: 4px; right: 10px; background: transparent;
    border: none; color: var(--text-secondary); cursor: pointer;
    font-size: 18px; font-family: var(--font-titel); padding: 4px 8px; z-index: 2;
  }
  #cb:hover { color: var(--text-primary); }
  #pc { display: contents; }

  /* ── Panel-Stueck: flex column, body wächst und scrollt ── */
  .panel-stueck {
    display: none;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }
  .panel-stueck[style*="display:flex"], .panel-stueck.active {
    display: flex !important;
  }

  /* ── Register-Overline + Titel ── */
  .rb {
    font-family: var(--font-titel); font-size: 10px; letter-spacing: 0.05em;
    padding: 15px 14px 0 14px;
    flex-shrink: 0;
  }
  :global(#panel h2) {
    font-family: var(--font-titel); font-size: 20px; font-weight: 400;
    margin: 4px 0 0 0; line-height: 1.3; color: var(--text-primary);
    padding: 0 14px;
    flex-shrink: 0;
  }

  /* ── Separator-Linie (Figma: Seperator_line, #afafaf, 1px) ── */
  .sep {
    width: 100%; height: 1px;
    background: var(--border);
    flex-shrink: 0;
    margin: 12px 0 0 0;
  }

  /* ── Layer-Selektor (Figma: Selector_Menue) ── */
  .lt {
    display: flex; gap: 0; flex-wrap: wrap;
    padding: 0; margin: 0;
    flex-shrink: 0;
  }
  .lb {
    background: transparent; border: none; color: var(--text-secondary);
    padding: 10px 10px; cursor: pointer;
    font-family: var(--font-inhalt); font-size: 11px;
  }
  .lb.on { color: var(--text-primary); }
  .lb.off { opacity: 0.3; cursor: default; }

  /* ── Schicht-Blöcke — scrollbarer Bereich ── */
  :global(.panel-body) {
    flex: 1 1 0;
    overflow-y: auto;
    overflow-x: hidden;
    min-height: 0;
    padding: 16px 14px 20px 14px;
  }

  /* Copy_line links = 2px Linie */
  :global(.panel-body .schicht) {
    border-left: 2px solid currentColor;
    padding-left: 12px;
    margin-bottom: 0;
    max-height: 50vh;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border-subtle) transparent;
  }
  :global(.panel-body .schicht::-webkit-scrollbar) { width: 3px; }
  :global(.panel-body .schicht::-webkit-scrollbar-thumb) { background: var(--border-subtle); border-radius: 2px; }
  :global(.panel-body .schicht::-webkit-scrollbar-track) { background: transparent; }

  /* Kern — Copy_line in Registerfarbe (via inherit/currentColor) */
  :global(.panel-body .schicht--kern) {
    border-left-color: currentColor;
  }
  :global(.panel-body .schicht--kern p) {
    font-family: var(--font-inhalt); font-size: 12px; line-height: 1.6; color: var(--text-primary);
  }

  /* Annotation — Copy_line immer Orange (#FE6901) */
  :global(.panel-body .schicht--annotation) {
    border-left-color: var(--annotation);
  }
  :global(.panel-body .schicht--annotation p) {
    font-family: var(--font-inhalt); font-size: 12px; line-height: 1.6; color: var(--text-primary);
  }

  /* Werkstatt — Copy_line Grey_light */
  :global(.panel-body .schicht--werkstatt) {
    border-left-color: var(--border);
  }
  :global(.panel-body .schicht--werkstatt p) {
    font-family: var(--font-inhalt); font-size: 12px; line-height: 1.6; color: var(--text-primary);
  }

  /* Quellen — Copy_line Grey_light */
  :global(.panel-body .schicht--quellen) {
    border-left-color: var(--border);
  }
  :global(.panel-body .schicht--quellen p) {
    font-family: var(--font-inhalt); font-size: 12px; line-height: 1.6; color: var(--text-primary);
  }

  /* Separator zwischen Schicht-Blöcken */
  :global(.panel-body .schicht + .schicht) {
    margin-top: 0;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  /* ── Bezüge — Dot + Titel + Register-Label ── */
  .bz { padding: 12px 14px 20px 14px; flex-shrink: 0; }
  .bzb {
    background: transparent; border: none;
    padding: 5px 8px; cursor: pointer; text-align: left;
    display: flex; align-items: center; gap: 6px; width: 100%;
    margin-bottom: 4px; color: var(--text-secondary); font-family: var(--font-inhalt); font-size: 11px;
  }
  .bzb:hover { color: var(--text-primary); }
  .bd { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
  .br { font-family: var(--font-label); font-size: 10px; color: var(--text-secondary); margin-left: auto; }
</style>
