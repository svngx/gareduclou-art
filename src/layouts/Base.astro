---
interface Props {
  title?: string;
}
const { title = 'Gare du Clou' } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style is:global>
    :root {
      /* Register */
      --spurweite: #6b8f71;
      --passage: #8a7f65;
      --ankunft: #8f6b6b;
      /* Neutral */
      --bg: #0a0a0a;
      --surface: #141414;
      --border: #2a2a2a;
      /* Text */
      --text-primary: #e8e4df;
      --text-secondary: #8a857e;
      --text-muted: #5a5651;
      /* Akzent */
      --accent: #c4b89a;
      /* Typografie */
      --font-inhalt: Georgia, 'Times New Roman', serif;
      --font-system: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: var(--bg);
      color: var(--text-primary);
      font-family: var(--font-inhalt);
      line-height: 1.65;
    }
    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
