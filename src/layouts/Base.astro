---
interface Props {
  title?: string;
}
const { title = 'Gare du Clou' } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style is:global>
    /* ── Snv Webfonts (URW Type Foundry, lizenziert via MyFonts) ── */
    @font-face {
      font-family: 'Snv D';
      src: url('/fonts/snv-regular.woff2') format('woff2'),
           url('/fonts/snv-regular.woff') format('woff');
      font-display: swap;
    }
    @font-face {
      font-family: 'Snv Cond D';
      src: url('/fonts/snv-cond.woff2') format('woff2'),
           url('/fonts/snv-cond.woff') format('woff');
      font-display: swap;
    }
    @font-face {
      font-family: 'Snv ExtCond D';
      src: url('/fonts/snv-extcond.woff2') format('woff2'),
           url('/fonts/snv-extcond.woff') format('woff');
      font-display: swap;
    }

    :root {
      /* Register — Figma-Tokens */
      --spurweite: #ff0000;
      --passage: #002395;
      --ankunft: #ffffff;
      --annotation: #FE6901;
      /* Neutral */
      --bg: #000000;
      --surface: #000000;
      --border: #afafaf;
      --border-subtle: #404040;
      /* Text */
      --text-primary: #ffffff;
      --text-secondary: #afafaf;
      /* Typografie — drei Snv-Schnitte */
      --font-titel: 'Snv D', Georgia, serif;
      --font-inhalt: 'Snv Cond D', Georgia, serif;
      --font-label: 'Snv ExtCond D', monospace;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: var(--bg);
      color: var(--text-primary);
      font-family: var(--font-inhalt);
      line-height: 1.65;
    }
    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
